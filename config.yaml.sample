# system configuration
system:
  env: 'public'
  addr: '0.0.0.0:8888' # 监听地址
  db-type: 'mysql' # 可选值：mysql、sqlite
  oss-type: 'minio' # 可选值：minio、cos

stb:
  uid: 'xxxxxxxxx@etv1'     # IPTV 用户名，打开你的iptv机顶盒，打开用户
  mac: 'xx:xx:xx:xx:xx:xx' # 机顶盒Mac地址 
  sn: '000xxxxxxxxxxxxxxx' # 机顶盒SN码 
  ip: '22.77.xx.x' # 专网IP地址
  type: 'B860A' # 机顶盒型号
  auth_host: '222.68.208.73:7001' # 认证服务器地址
  # OpenWrt SSH 配置（可选），用于自动检测 IPTV 专网接口 IP 变化并触发重认证
  # 配置后，每 5 分钟 SSH 到 OpenWrt 检测 DHCP IP 是否变化，变化则自动重认证
  openwrt_host: '192.168.0.x'         # OpenWrt 路由器 IP，如 192.168.1.1
  openwrt_port: 22         # SSH 端口，默认 22
  openwrt_user: 'root'     # SSH 用户名
  openwrt_pass: 'xxxxxx'         # SSH 密码
  openwrt_if: 'wan.85'       # IPTV 专网接口名称，如 eth0.85、iptv、pppoe-iptv

#相关api
#例子
#http://192.168.0.131:8888/api/m3u8
#http://192.168.0.131:8888/api/tsM3u8
#http://192.168.0.131:8888/api/epg

#相关api
#例子
#http://192.168.0.131:8888/api/m3u8
#http://192.168.0.131:8888/api/epg
#http://192.168.0.131:8888/api/schedule
# EPG 配置
epg:
  generator: 'IPTV Spider'
  source: 'sh-tel'
  xml_url: ''
  rtsp_url: 'http://192.168.1.131:3333/rtp/'
  rtp_url: 'http://192.168.1.131:3333/rtsp/'
  logo_url: ''
  fetch_cron: '0 0 9,17,22 * * *' # EPG拉取定时任务
  playseek: '&playseek={utc:YmdHMS}-{utcend:YmdHMS}'
  

oss:
  enable: true
  upload_cron: '0 20 0,8,16 * * *'
  endpoint: 'xxx.com'
  use-ssl: false
  bucket: 'epg'
  access-key: 'xxxxxxxxx'
  secret-key: 'xxxxxxxxx'

# redis configuration
redis:
  db: 0
  addr: '10.0.0.10:6379'
  password: ''

cache:
  type: memory    # memory、redis
  prefix: 'CM'
  memory_interval: 60        # 使用内存缓存时生效, 内存回收间隔
  default_timeout: 240       # 默认缓存时间 单位：分钟

# mysql connect configuration
mysql:
  path: '10.0.0.200'
  config: 'parseTime=True'
  db-name: 'iptv_spider'
  username: 'spider'
  password: 'sh-tel-spider'
  max-idle-conns: 10
  max-open-conns: 100
  log-mode: 'error'
  log-zap: false

# sqlite connect configuration
sqlite:
  path: './data/iptv_spider.db' # 数据库文件路径，会自动创建
  max-idle-conns: 10
  max-open-conns: 100
  log-mode: 'error'
  log-zap: false

zap:
  level: 'debug'
  format: 'console'
  prefix: '[iptv-spider-sh]'
  director: 'log'
  link-name: 'latest_log'
  show-line: false
  encode-level: 'LowercaseColorLevelEncoder'
  stacktrace-key: 'stacktrace'
  log-in-console: false

access-log:
  enabled: true
  director: 'log/access'
  format: 'console'
  log-in-console: false
  max-age: 7
  rotation-time: 24


