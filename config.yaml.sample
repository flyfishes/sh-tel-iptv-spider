oss:
  enable: true
  upload_cron: '0 20 0,8,16 * * *'
  endpoint: 'xxx.com'
  use-ssl: false
  bucket: 'epg'
  access-key: 'xxxxxxxxx'
  secret-key: 'xxxxxxxxx'

# redis configuration
redis:
  db: 0
  addr: '10.0.0.10:6379'
  password: ''

cache:
  type: memory    # memory、redis
  prefix: 'CM'
  memory_interval: 60        # 使用内存缓存时生效, 内存回收间隔
  default_timeout: 240       # 默认缓存时间 单位：分钟

# mysql connect configuration
mysql:
  path: '10.0.0.200'
  config: 'parseTime=True'
  db-name: 'iptv_spider'
  username: 'spider'
  password: 'sh-tel-spider'
  max-idle-conns: 10
  max-open-conns: 100
  log-mode: 'error'
  log-zap: false

# sqlite connect configuration
sqlite:
  path: './data/iptv_spider.db' # 数据库文件路径，会自动创建
  max-idle-conns: 10
  max-open-conns: 100
  log-mode: 'error'
  log-zap: false

zap:
  level: 'debug'
  format: 'console'
  prefix: '[iptv-spider-sh]'
  director: 'log'
  link-name: 'latest_log'
  show-line: false
  encode-level: 'LowercaseColorLevelEncoder'
  stacktrace-key: 'stacktrace'
  log-in-console: false

access-log:
  enabled: true
  director: 'log/access'
  format: 'console'
  log-in-console: false
  max-age: 7
  rotation-time: 24


