# system configuration
system:
  env: 'public'
  addr: '0.0.0.0:8888' # 监听地址
  db-type: 'mysql' # 可选值：mysql、sqlite
  oss-type: 'minio' # 可选值：minio、cos

stb:
  uid: 'xxxxxxxxx@etv1'     # IPTV 用户名，打开你的iptv机顶盒，打开用户
  mac: 'xx:xx:xx:xx:xx:xx' # 机顶盒Mac地址 
  sn: '000xxxxxxxxxxxxxxx' # 机顶盒SN码 
  ip: '22.77.xx.x' # 专网IP地址
  type: 'B860A' # 机顶盒型号
  auth_host: '222.68.208.73:7001' # 认证服务器地址
  # OpenWrt SSH 配置（可选），用于自动检测 IPTV 专网接口 IP 变化并触发重认证
  # 配置后，每 5 分钟 SSH 到 OpenWrt 检测 DHCP IP 是否变化，变化则自动重认证
  openwrt_host: '192.168.0.x'         # OpenWrt 路由器 IP，如 192.168.1.1
  openwrt_port: 22         # SSH 端口，默认 22
  openwrt_user: 'root'     # SSH 用户名
  openwrt_pass: 'xxxxxx'         # SSH 密码
  openwrt_if: 'wan.85'       # IPTV 专网接口名称，如 eth0.85、iptv、pppoe-iptv

#相关api
#例子
#http://192.168.0.131:8888/api/m3u8
#http://192.168.0.131:8888/api/tsM3u8
#http://192.168.0.131:8888/api/epg

#相关api
#例子
#http://192.168.0.131:8888/api/m3u8
#http://192.168.0.131:8888/api/epg
#http://192.168.0.131:8888/api/schedule
# EPG 配置
epg:
  generator: 'IPTV Spider'
  source: 'sh-tel'
  xml_url: ''
  rtsp_url: 'http://192.168.1.131:3333/rtp/'
  rtp_url: 'http://192.168.1.131:3333/rtsp/'
  logo_url: ''
  fetch_cron: '0 0 9,17,22 * * *' # EPG拉取定时任务
  playseek: '&playseek={utc:YmdHMS}-{utcend:YmdHMS}'
  #过滤表
  exclude_channels:
    - "体育频道"
    - "好享购物"
    - "央广购物"
    - "东方购物-1"
    - "东方购物-2"
    - "卡酷卡通"

#排序表
  name_sequence: 
    - name: "CCTV-5"
    - name: "CCTV-5+"
    - name: "CCTV-16HD"
